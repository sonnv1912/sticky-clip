{
   "name": "sticky-clip-workspace",
   "license": "MIT",
   "private": true,
   "scripts": {
      "dev": "turbo run dev",
      "dev:app": "yarn workspace sticky-clip dev",
      "dev:document": "yarn workspace sticky-clip-document dev",
      "build": "turbo run build",
      "build:app": "yarn workspace sticky-clip build",
      "build:document": "yarn workspace sticky-clip-document build",
      "deploy:document": "yarn build:document && gh-pages -d ./apps/document/dist",
      "preview:document": "yarn workspace sticky-clip-document preview"
   },
   "devDependencies": {
      "gh-pages": "^6.2.0",
      "turbo": "^2.5.5",
      "typescript": "6.0.3"
   },
   "engines": {
      "node": ">=20"
   },
   "packageManager": "yarn@1.22.22",
   "workspaces": ["apps/*", "packages/*"]
}
